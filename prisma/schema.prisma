generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String
  subject   String
  message   String   @db.Text
  createdAt DateTime @default(now())

  @@map("contact_messages")
}
